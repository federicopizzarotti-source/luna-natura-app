<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sfondo_principale">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp"
            android:paddingStart="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@android:color/transparent"
                android:tint="@color/testo_principale"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/titolo_about"
                android:textColor="@color/testo_principale"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/bordo"/>

        <!-- Luna decorativa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌕"
                android:textSize="56sp"/>
        </LinearLayout>

        <!-- Titolo app -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/testo_principale"
            android:textSize="24sp"
            android:fontFamily="serif"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_versione"
            android:textColor="@color/testo_muto"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Card descrizione -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_bg_chiaro"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_descrizione"
                android:textColor="@color/testo_secondario"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6"/>
        </LinearLayout>

        <!-- Card info autore -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_bg_chiaro"
            android:padding="16dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/about_label_autore"
                    android:textColor="@color/testo_muto" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/about_autore"
                    android:textColor="@color/testo_principale" android:textSize="13sp"
                    android:fontFamily="serif"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/bordo_leggero" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/about_label_email"
                    android:textColor="@color/testo_muto" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/about_email"
                    android:textColor="@color/testo_principale" android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/bordo_leggero" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/about_label_versione"
                    android:textColor="@color/testo_muto" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/about_versione"
                    android:textColor="@color/testo_principale" android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/bordo_leggero" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/about_label_data"
                    android:textColor="@color/testo_muto" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/about_data"
                    android:textColor="@color/testo_principale" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card disclaimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_bg_chiaro"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_label_disclaimer"
                android:textColor="@color/testo_muto"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_disclaimer"
                android:textColor="@color/testo_secondario"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.6"/>
        </LinearLayout>

        <!-- Card licenza -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_bg_chiaro"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_label_licenza"
                android:textColor="@color/testo_muto"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_licenza"
                android:textColor="@color/testo_secondario"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.6"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
